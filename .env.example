# Домен для Caddy (используется в docker-compose.yml)
DOMAIN=sub.example.com

# Учётные данные панели
ADMIN_USER=admin
ADMIN_PASS=your-strong-password-here

# Токен для публичной ссылки подписки (/subscribe/PC?token=XXX)
# Сгенерировать: openssl rand -hex 24
SUB_TOKEN=replace-with-random-token

# Секрет для подписи сессий (можно любую длинную строку)
# Сгенерировать: openssl rand -hex 32
SESSION_SECRET=replace-with-random-secret

# Таймаут запроса к серверам подписки (мс)
FETCH_TIMEOUT_MS=8000
